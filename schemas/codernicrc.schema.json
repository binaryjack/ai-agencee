{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-agencee.dev/schemas/codernicrc.json",
  "title": "Codernic Configuration",
  "description": "Configuration file for Codernic codebase indexer",
  "type": "object",
  "properties": {
    "indexer": {
      "type": "object",
      "description": "Codebase indexer configuration",
      "properties": {
        "languages": {
          "type": "array",
          "description": "Programming languages to index (e.g., [\"typescript\", \"javascript\", \"python\"])",
          "items": {
            "type": "string",
            "enum": ["typescript", "javascript", "python", "java", "csharp", "go", "rust", "ruby", "php"]
          },
          "default": ["typescript", "javascript"]
        },
        "respectGitignore": {
          "type": "boolean",
          "description": "Whether to respect .gitignore files when discovering files",
          "default": true
        },
        "forceIncludePatterns": {
          "type": "array",
          "description": "Glob patterns to force-include even if git-ignored (e.g., [\"_private/**\", \"internal/**\"])",
          "items": {
            "type": "string"
          },
          "default": [],
          "examples": [
            ["_private/**"],
            ["_private/**", "internal/**", "vendor/**"]
          ]
        },
        "excludePatterns": {
          "type": "array",
          "description": "Glob patterns to exclude from indexing (e.g., [\"node_modules\", \"dist\"])",
          "items": {
            "type": "string"
          },
          "default": ["node_modules", "dist", "build", ".git", "coverage"]
        },
        "includePatterns": {
          "type": "array",
          "description": "Glob patterns to explicitly include (overrides excludePatterns)",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
