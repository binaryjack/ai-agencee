{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-agencee.dev/schemas/project-intelligence.schema.json",
  "title": "ProjectIntelligence",
  "description": "AI Agencee project intelligence output written to .ai/project-intelligence.json",
  "type": "object",
  "required": ["version", "generatedAt", "projectRoot", "techStack", "fileCount", "agentFiles", "secrets"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "projectRoot": { "type": "string", "minLength": 1 },
    "techStack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fileCount": { "type": "integer", "minimum": 0 },
    "agentFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "line", "pattern", "severity", "masked"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "pattern": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium"] },
          "masked": { "type": "string", "maxLength": 12 }
        }
      }
    }
  }
}
