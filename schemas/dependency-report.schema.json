{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ai-agencee/schemas/dependency-report.schema.json",
  "title": "Dependency Audit Report",
  "description": "Structured output schema for the Dependency Audit agent",
  "type": "object",
  "required": ["runId", "verdict", "packages"],
  "properties": {
    "runId": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "warn"],
      "description": "Overall audit verdict"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "status"],
        "properties": {
          "name":            { "type": "string" },
          "version":         { "type": "string" },
          "status":          { "type": "string", "enum": ["ok", "outdated", "vulnerable", "license-issue"] },
          "latestVersion":   { "type": "string" },
          "vulnerabilities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "severity"],
              "properties": {
                "id":          { "type": "string" },
                "severity":    { "type": "string", "enum": ["low", "moderate", "high", "critical"] },
                "description": { "type": "string" },
                "fixedIn":     { "type": "string" }
              }
            }
          },
          "license":         { "type": "string" },
          "licenseStatus":   { "type": "string", "enum": ["allowed", "restricted", "unknown"] }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total":         { "type": "integer" },
        "vulnerable":    { "type": "integer" },
        "outdated":      { "type": "integer" },
        "licenseIssues": { "type": "integer" }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
