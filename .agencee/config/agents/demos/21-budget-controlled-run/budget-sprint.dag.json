    "audience-research":  ["audience-profile"],
    "persona-generation": ["audience-profile"],
    "content-strategy":   ["strategy"],
    "campaign-planning":  ["strategy"],
    "budget-review":      ["budget-gate"],
    "spend-forecast":     ["budget-gate"]
  },
  "metadata": {
    "ip": "IP-08",
