# Codernic Orchestrator Configuration
# Copy this file to .env and customize as needed

# ========================================
# Rollback & Snapshot Configuration
# ========================================

# Maximum number of snapshots to keep per project
# CODERNIC_MAX_SNAPSHOTS=10

# Maximum age of snapshots in milliseconds (default: 7 days)
# CODERNIC_SNAPSHOT_MAX_AGE_MS=604800000

# Enable automatic cleanup of old snapshots
# CODERNIC_AUTO_CLEANUP_SNAPSHOTS=true

# ========================================
# Learning System Configuration
# ========================================

# Enable learning system
# CODERNIC_LEARNING_ENABLED=true

# Maximum learning examples to include in prompts
# CODERNIC_MAX_LEARNING_EXAMPLES=5

# Minimum confidence score to include example (0-1)
# CODERNIC_MIN_LEARNING_CONFIDENCE=0.7

# ========================================
# Production Hardening - Retry Configuration
# ========================================

# Maximum number of retries
# CODERNIC_MAX_RETRIES=3

# Initial retry delay in milliseconds
# CODERNIC_RETRY_INITIAL_DELAY_MS=1000

# Backoff multiplier for exponential backoff
# CODERNIC_RETRY_BACKOFF_MULTIPLIER=2

# Maximum retry delay in milliseconds (30 seconds)
# CODERNIC_RETRY_MAX_DELAY_MS=30000

# ========================================
# Production Hardening - Circuit Breaker
# ========================================

# Failure threshold to open circuit
# CODERNIC_CIRCUIT_FAILURE_THRESHOLD=5

# Timeout to try half-open in milliseconds (1 minute)
# CODERNIC_CIRCUIT_RESET_TIMEOUT_MS=60000

# Success threshold to close circuit when half-open
# CODERNIC_CIRCUIT_SUCCESS_THRESHOLD=2

# ========================================
# Production Hardening - Rate Limiter
# ========================================

# Maximum requests per window
# CODERNIC_RATE_LIMIT_MAX_REQUESTS=60

# Time window in milliseconds (1 minute)
# CODERNIC_RATE_LIMIT_WINDOW_MS=60000

# Block when limit exceeded (vs queue)
# CODERNIC_RATE_LIMIT_BLOCK_ON_EXCEEDED=false

# ========================================
# Production Hardening - Observability
# ========================================

# Enable metrics collection
# CODERNIC_METRICS_ENABLED=true

# Enable structured logging
# CODERNIC_LOGGING_ENABLED=true

# ========================================
# Cost Optimization - Cache
# ========================================

# Enable response caching
# CODERNIC_CACHE_ENABLED=true

# Cache TTL in milliseconds (7 days)
# CODERNIC_CACHE_TTL_MS=604800000

# Maximum cache entries
# CODERNIC_CACHE_MAX_ENTRIES=1000

# ========================================
# Cost Optimization - Compression
# ========================================

# Enable prompt compression
# CODERNIC_COMPRESSION_ENABLED=true

# Target compression ratio (0-1, e.g., 0.7 = reduce by 30%)
# CODERNIC_COMPRESSION_TARGET_RATIO=0.7

# ========================================
# Cost Optimization - Budget
# ========================================

# Budget alert thresholds (comma-separated, 0-1)
# CODERNIC_BUDGET_ALERT_THRESHOLDS=0.8,0.95

# Block execution when budget exceeded
# CODERNIC_BUDGET_BLOCK_ON_EXCEEDED=false

# ========================================
# Test Runner Configuration
# ========================================

# Test timeout in milliseconds (60 seconds)
# CODERNIC_TEST_TIMEOUT_MS=60000

# ========================================
# Database Configuration
# ========================================

# Base directory for database files (relative to HOME)
# CODERNIC_DB_DIR=.codernic

# ========================================
# Approval Configuration
# ========================================

# Maximum lines to show per patch
# CODERNIC_APPROVAL_MAX_LINES_PER_PATCH=50
